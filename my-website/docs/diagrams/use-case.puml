@startuml
left to right direction

actor "Гость" as guest
actor "Авторизованный\nпользователь" as auth
actor "Потерявший" as loser
actor "Нашедший" as finder

loser --|> auth
finder --|> auth

rectangle "Система Lost&Found" {
  usecase "Просматривать карту объявлений" as UC1
  usecase "Регистрироваться" as UC2
  usecase "Восстановить доступ" as UC3
  usecase "Авторизоваться" as UC4
  usecase "Искать объявления" as UC5
  usecase "Фильтровать объявления" as UC6
  usecase "Публиковать объявление\n«Потерял»" as UC7
  usecase "Публиковать объявление\n«Нашёл»" as UC8
  usecase "Указать место" as UC9
  usecase "Откликнуться\nна объявление" as UC10
  usecase "Пройти owner-check" as UC11
  usecase "Закрыть объявление" as UC12
}

guest --> UC1
guest --> UC2
guest --> UC4
guest --> UC5

auth --> UC1
auth --> UC5
auth --> UC7
auth --> UC8
auth --> UC10
auth --> UC12

UC7 ..> UC9 : <<include>>
UC8 ..> UC9 : <<include>>
UC10 ..> UC11 : <<include>>
UC4 <.. UC3 : <<extend>>
UC5 <.. UC6 : <<extend>>
@enduml
