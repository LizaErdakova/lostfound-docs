@startuml
title UC-05 — Публикация объявления «Потерял»

actor "Пользователь\n(авторизованный)" as u
participant "Сайт Lost&Found" as app
participant "API карты" as map
participant "Backend Lost&Found" as b
database "База данных" as db

note over u, app
Предусловие: пользователь авторизован
end note

u -> app: Нажимает "Создать объявление"
activate app
app --> u: Показать форму создания объявления

u -> app: Выбирает тип "Потерял"
u -> app: Выбирает категорию
app --> u: Показать обязательные поля\nи подсказку "что можно/нельзя публиковать"

u -> app: Указывает дату и примерное время потери

app -> map: Запросить карту Москвы
activate map
alt Карта доступна
    map --> app: Карта загружена
    app --> u: Показать карту для выбора точки
    u -> app: Указывает место на карте
else Карта недоступна
    map --> app: Ошибка загрузки карты
    app --> u: Показать сообщение\n"Карта временно недоступна"
    u -> app: Вводит место текстом\n(район/адрес/ориентир)
end
deactivate map

u -> app: Заполняет описание/приметы\nи категорийные поля

opt Пользователь добавляет фото
    u -> app: Добавляет фото
    app --> u: Показать предупреждение\nо безопасной публикации фото
end

loop Повторная отправка до успешной проверки
    u -> app: Нажимает "Опубликовать"
    app -> b: Проверить данные объявления
    activate b

    alt Не заполнены обязательные поля
        b --> app: Ошибка валидации
        deactivate b
        app --> u: Подсветить незаполненные поля
        u -> app: Исправляет обязательные поля

    else Точка вне Москвы
        b --> app: Ошибка географии
        deactivate b
        app --> u: Показать сообщение\n"Публикация доступна только в Москве"

        alt Исправление через карту
            u -> app: Изменяет место на карте
        else Исправление текстом
            u -> app: Вводит другое место текстом
        end

    else Данные корректны
        b --> app: Данные валидны
        deactivate b
        break Проверка завершена успешно
        end
    end
end

app -> b: Создать объявление
activate b
b -> db: Сохранить объявление
activate db
db --> b: Объявление сохранено
deactivate db

b --> app: Публикация успешна
deactivate b
app --> u: Открыть карточку объявления
deactivate app
@enduml
